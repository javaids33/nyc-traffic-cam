# Cloudflare Pages cache + security headers.
# Cache the bundled JS/CSS assets for a year (Vite hashes the
# filenames so stale caches can't bite). HTML stays uncached so a
# new deploy is visible on next nav. The /api/* routes are dynamic
# (CF Pages Functions backed by KV) — keep them uncached.

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.json
  Cache-Control: public, max-age=3600

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=86400

/og.png
  Cache-Control: public, max-age=604800

/

  Cache-Control: public, max-age=300
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
